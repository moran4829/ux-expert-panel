# Firebase (required for login + cloud sync)
# Copy from Firebase Console → Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated admin emails (see all users & projects in Admin panel)
VITE_ADMIN_EMAILS=your.email@gmail.com

# Optional: defaults used by the Vite dev server when task routing is not sent from the UI.

# Ollama (recommended POC)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# LM Studio (OpenAI-compatible)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e4b

# GEMINI_API_KEY: Reserved for future cloud provider (not wired in UI yet).
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
