rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin emails — replace with your email(s) or use Custom Claims (admin: true)
    function isAdmin() {
      return isSignedIn() && request.auth.token.email in [
        'moranpe@gmail.com'
      ];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/data/{docId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/projects/{projectId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/personas/{personaId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Collection group query for admin — all projects
    match /{path=**}/projects/{projectId} {
      allow read: if isAdmin();
    }
  }
}
